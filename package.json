{
  "name": "@buzz-dee/potrace-ts",
  "version": "1.3.0",
  "private": false,
  "type": "module",
  "description": "typescript potrace module",
  "author": "Sebastian Schlatow <buzz-dee@riseup.net>",
  "packageManager": "pnpm@11.11.0",
  "license": "GPL-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BuZZ-dEE/potrace-ts.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "dev": "tsc -w",
    "build": "rolldown --config --cleanDir && tsc --emitDeclarationOnly",
    "test": "jest",
    "lint": "eslint --ext .js,.ts src"
  },
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/debug": "^4.1.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "chai": "^6.2.2",
    "eslint": "^10.7.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.4.2",
    "rolldown": "^1.0.0",
    "ts-jest": "^29.4.11",
    "tslib": "^2.6.2",
    "tsx": "^4.11.0",
    "typescript": "^6.0.3"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "keywords": [
    "potrace",
    "typescript",
    "image to svg"
  ],
  "productName": "potrace-ts",
  "jest": {
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "moduleNameMapper": {
      "@/(.*)$": "<rootDir>/$1"
    },
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/"
    ],
    "preset": "ts-jest",
    "transform": {
      "^.+\\.ts?$": "ts-jest"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/dist/"
    ],
    "maxConcurrency": 10,
    "maxWorkers": 1
  }
}
